# ─────────────────────────────────────────────────────────────────────────────
# JobSignal — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Create the database first: createdb jobsignal
# Then run migrations:      alembic upgrade head
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/jobsignal

# ── JSearch (RapidAPI) ────────────────────────────────────────────────────────
# Sign up at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month. Set to empty string to skip this source.
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Adzuna ────────────────────────────────────────────────────────────────────
# Sign up at: https://developer.adzuna.com
# Free tier: unlimited. Set both to empty string to skip this source.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ── Anthropic (used in Module 2+ for AI extraction and generation) ────────────
# Sign up at: https://console.anthropic.com
# Not required for Module 1 ingestion.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional overrides (all have sensible defaults) ───────────────────────────
# Comma-separated list of countries to query on Adzuna.
# ADZUNA_COUNTRIES=["us","gb"]

# Maximum results to fetch per query per API.
# INGESTION_MAX_RESULTS_PER_QUERY=100

# How often to run the scheduled ingestion, in hours.
# SCHEDULE_INTERVAL_HOURS=24
